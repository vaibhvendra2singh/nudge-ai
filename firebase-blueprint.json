{
  "entities": {
    "Task": {
      "title": "Task",
      "description": "A task or list item with deadlines, priority, and checkable subtasks.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier of the task."
        },
        "title": {
          "type": "string",
          "description": "Short description of what needs to be done."
        },
        "details": {
          "type": "string",
          "description": "Extra notes, links, or context."
        },
        "priority": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "description": "Urgency tier."
        },
        "deadline": {
          "type": "string",
          "description": "Target date for task completion."
        },
        "completed": {
          "type": "boolean",
          "description": "Completion state."
        },
        "project": {
          "type": "string",
          "description": "Project categorization label."
        },
        "timeSlot": {
          "type": "string",
          "description": "Scheduled time block."
        },
        "subtasks": {
          "type": "array",
          "description": "List of smaller steps to complete the task."
        },
        "aiNudge": {
          "type": "string",
          "description": "Optional AI-generated nudge text."
        },
        "aiBreakdownGenerated": {
          "type": "boolean",
          "description": "Whether AI checklist was run."
        },
        "userId": {
          "type": "string",
          "description": "The owner of this task."
        },
        "updatedAt": {
          "type": "number",
          "description": "Update timestamp."
        }
      },
      "required": ["id", "title", "completed", "userId"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "The user's personal display preferences and settings.",
      "type": "object",
      "properties": {
        "userName": {
          "type": "string",
          "description": "The custom display name of the user."
        },
        "updatedAt": {
          "type": "number",
          "description": "Update timestamp."
        }
      },
      "required": ["userName"]
    }
  },
  "firestore": {
    "tasks/{taskId}": {
      "schema": "Task",
      "description": "Secure space populated by tasks owned by standard user accounts."
    },
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "Basic profile configurations for custom name tags."
    }
  }
}
